# Server Configuration
PORT=3000
NODE_ENV=development
FORCE_HTTPS=false

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=spectrum_legal

# JWT Secret (use a strong random string)
JWT_SECRET=your_very_long_and_secure_random_string_here

# Email Configuration
EMAIL_PROVIDER=namecheap
EMAIL_USER=admin@chamber.telente.site
EMAIL_PASS=your-email-password-or-app-password
EMAIL_FROM_NAME=Legal Spectrum
EMAIL_FROM=Legal Spectrum <admin@chamber.telente.site>

# SMTP (Namecheap Private Email)
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=465
EMAIL_SECURE=true
